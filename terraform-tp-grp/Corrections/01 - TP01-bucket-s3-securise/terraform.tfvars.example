# -----------------------------------------------------------------------------
# terraform.tfvars.example
# Copier ce fichier en terraform.tfvars et renseigner les valeurs.
# terraform.tfvars est ignore par Git (.gitignore) pour eviter les fuites.
# -----------------------------------------------------------------------------

# Email de l'owner du bucket. Obligatoire (pas de default dans variables.tf).
owner = "votre-email@example.com"

# Environnement cible. Laisser "dev" pour la formation.
# environment = "dev"

# Prefixe du nom de bucket. Les 3 elements se combinent en :
#   <bucket_prefix>-<account_id>-<random_pet>
# bucket_prefix = "formation-tp01"

# Region AWS. Par defaut eu-west-1 (Ireland).
# aws_region = "eu-west-1"
